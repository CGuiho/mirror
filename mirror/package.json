{
  "name": "@guiho40/mirror",
  "description": "GUIHO Mirror",
  "version": "2.2.0",
  "main": "library/mirror.js",
  "types": "library/mirror.d.ts",
  "module": "source/mirror.ts",
  "type": "module",
  "readmeFilename": "../readme.md",
  "keywords": [],
  "license": "PROPRIETARY",
  "author": {
    "name": "Cristóvão GUIHO",
    "email": "cg@guiho.co",
    "url": "https://guiho.co/cg"
  },
  "sideEffects": false,
  "bin": {
    "mirror": "./bin/mirror.exe"
  },
  "scripts": {
    "dev": "bun run --watch source/mirror.ts",
    "build": "rm -rf library && tsc -p .",
    "binary": "bun build source/mirror.ts --compile --outfile bin/mirror",
    "bundle": "rm -rf bundle && bun build source/mirror.ts --outdir bundle --target node --sourcemap=linked",
    "typecheck": "tsc -p . --noEmit",
    "clean": "rm -rf .temp",
    "clean-build": "rm -rf build library bundle",
    "clean-installation": "rm -rf node_modules bun.lock",
    "_tc": "bun run typecheck",
    "_ci": "bun clean && bun clean-build && bun clean-installation",
    "_up": "bun _gaa && bun x taze --install --write --interactive",
    "_upb": "bun _gaa && bun update --interactive",
    "_uid": "bun nanoid --alphabet abcdefghijklmnopqrstuvwxyz-_0123456789",
    "_gaa": "npx google-artifactregistry-auth"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/CGuiho/mirror.git",
    "directory": "mirror"
  },
  "homepage": "https://github.com/CGuiho/mirror#readme",
  "bugs": "https://github.com/CGuiho/mirror/issues",
  "files": [
    "library/",
    "types/",
    "docs/",
    "bin/",
    "CHANGELOG.md",
    "LICENSE.md",
    "docs.md"
  ],
  "dependencies": {
    "semver": "^7.7.3"
  },
  "devDependencies": {
    "@guiho40/mirror": "^1.2.0",
    "@types/bun": "latest",
    "@types/semver": "^7.7.1"
  },
  "peerDependencies": {
    "typescript": "^5.8.2"
  }
}